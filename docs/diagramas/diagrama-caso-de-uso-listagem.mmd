flowchart LR
  actor_cliente["<<actor>>\nCliente"]
  actor_atendimento["<<actor>>\nGarcom/Host"]

  subgraph sistema["Sistema Cardapio Digital (menu-restaurante)"]
    uc_acessar([Acessar cardapio])
    uc_listar_categorias([Listar categorias])
    uc_listar_itens([Listar itens do menu])
    uc_buscar([Buscar por nome ou descricao])
    uc_filtrar([Filtrar itens por categoria])
    uc_ordenar([Ordenar itens por criterio])
    uc_detalhes([Visualizar detalhes do prato])
    uc_carregar([Carregar dados do JSON])
    uc_contagem([Exibir quantidade de resultados])
  end

  actor_cliente --- uc_acessar
  actor_cliente --- uc_listar_itens
  actor_cliente --- uc_buscar
  actor_cliente --- uc_filtrar
  actor_cliente --- uc_ordenar
  actor_cliente --- uc_detalhes

  actor_atendimento --- uc_acessar
  actor_atendimento --- uc_listar_itens
  actor_atendimento --- uc_detalhes

  uc_acessar -. "<<include>>" .-> uc_carregar
  uc_carregar -. "<<include>>" .-> uc_listar_categorias
  uc_carregar -. "<<include>>" .-> uc_listar_itens

  uc_buscar -. "<<extend>>" .-> uc_listar_itens
  uc_filtrar -. "<<extend>>" .-> uc_listar_itens
  uc_ordenar -. "<<extend>>" .-> uc_listar_itens
  uc_detalhes -. "<<extend>>" .-> uc_listar_itens
  uc_listar_itens -. "<<include>>" .-> uc_contagem

  classDef actor fill:transparent,stroke:transparent,color:#222;
  class actor_cliente,actor_atendimento actor;
